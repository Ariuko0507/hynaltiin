        <record id="user_dept_head_hr" model="users">
            <field name="name">Enkh HR Head</field>
            <field name="email">enkh.hr@company.com</field>
            <field name="role_id" ref="role_department_head"/>
            <field name="position">department_head</field>
            <field name="status">active</field>
            <field name="is_active" eval="True"/>
            <field name="manager_id" ref="user_manager"/>
            <field name="department_id" ref="dept_hr"/>
        </record>
        
        <record id="user_dept_head_operations" model="users">
            <field name="name">Enkh Operations Head</field>
            <field name="email">enkh.ops@company.com</field>
            <field name="role_id" ref="role_department_head"/>
            <field name="position">department_head</field>
            <field name="status">active</field>
            <field name="is_active" eval="True"/>
            <field name="manager_id" ref="user_manager"/>
            <field name="department_id" ref="dept_operations"/>
        </record>
        
        <record id="user_dept_head_sales" model="users">
            <field name="name">Enkh Sales Head</field>
            <field name="email">enkh.sales@company.com</field>
            <field name="role_id" ref="role_department_head"/>
            <field name="position">department_head</field>
            <field name="status">active</field>
            <field name="is_active" eval="True"/>
            <field name="manager_id" ref="user_manager"/>
            <field name="department_id" ref="dept_sales"/>
        </record>
        
        <record id="user_dept_head_marketing" model="users">
            <field name="name">Enkh Marketing Head</field>
            <field name="email">enkh.mkt@company.com</field>
            <field name="role_id" ref="role_department_head"/>
            <field name="position">department_head</field>
            <field name="status">active</field>
            <field name="is_active" eval="True"/>
            <field name="manager_id" ref="user_manager"/>
            <field name="department_id" ref="dept_marketing"/>
        </record>
        
        <record id="user_dept_head_technology" model="users">
            <field name="name">Enkh Technology Head</field>
            <field name="email">enkh.tech@company.com</field>
            <field name="role_id" ref="role_department_head"/>
            <field name="position">department_head</field>
            <field name="status">active</field>
            <field name="is_active" eval="True"/>
            <field name="manager_id" ref="user_manager"/>
            <field name="department_id" ref="dept_technology"/>
        </record>

        <!-- Update Department Managers -->
        <record id="dept_finance_manager" model="departments">
            <field name="id" ref="dept_finance"/>
            <field name="manager_id" ref="user_dept_head_finance"/>
        </record>
        
        <record id="dept_hr_manager" model="departments">
            <field name="id" ref="dept_hr"/>
            <field name="manager_id" ref="user_dept_head_hr"/>
        </record>
        
        <record id="dept_operations_manager" model="departments">
            <field name="id" ref="dept_operations"/>
            <field name="manager_id" ref="user_dept_head_operations"/>
        </record>
        
        <record id="dept_sales_manager" model="departments">
            <field name="id" ref="dept_sales"/>
            <field name="manager_id" ref="user_dept_head_sales"/>
        </record>
        
        <record id="dept_marketing_manager" model="departments">
            <field name="id" ref="dept_marketing"/>
            <field name="manager_id" ref="user_dept_head_marketing"/>
        </record>
        
        <record id="dept_technology_manager" model="departments">
            <field name="id" ref="dept_technology"/>
            <field name="manager_id" ref="user_dept_head_technology"/>
        </record>

        <!-- Users - Team Leaders -->
        <record id="user_leader_finance" model="users">
            <field name="name">Oyu Finance Leader</field>
            <field name="email">oyu.leader1@company.com</field>
            <field name="role_id" ref="role_team_leader"/>
