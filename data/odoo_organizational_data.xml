            <field name="department_id" ref="dept_sales"/>
        </record>
        
        <record id="user_leader_marketing" model="users">
            <field name="name">Bold Marketing Leader</field>
            <field name="email">bold.leader5@company.com</field>
            <field name="role_id" ref="role_team_leader"/>
            <field name="position">team_leader</field>
            <field name="status">active</field>
            <field name="is_active" eval="True"/>
            <field name="manager_id" ref="user_dept_head_marketing"/>
